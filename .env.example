# ─── DEFAULT: z.ai GLM-4.6V (OpenAI Chat Completions format) ────────────
# Only VISION_API_KEY is strictly required — baseURL/model fall back to the
# baked provider defaults shown below. Override them only if you need to.
VISION_PROVIDER=openai
VISION_BASE_URL=https://api.z.ai/api/coding/paas/v4
VISION_API_KEY=your-z.ai-api-key-here
VISION_MODEL=glm-4.6v
# thinking mode: "disabled" (default — fast/cheap for OCR & perception) | "enabled" (deeper reasoning)
VISION_THINKING=disabled

# ─── Shared optional tuning ────────────────────────────────────────────────
VISION_MAX_TOKENS=1024
VISION_TIMEOUT_MS=60000

# ─── RECOMMENDED (always): VISION_* aliases ────────────────────────────────
# These take precedence over the provider-specific vars below and never collide
# with inherited process env (e.g. a coding agent's own ANTHROPIC_* credentials,
# which bun's .env loader will NOT override). `anthropic` provider → /v1/messages;
# `openai` → {base}/chat/completions.
#
# NOTE on OpenAI base URLs: the base does NOT have to end in `/v1`. z.ai ends in
# `/v4`; opencode zen ends in `/v1`. The code POSTs to `{base}/chat/completions`,
# so set base to whatever prefix yields that path on your gateway.

# ─── Alternative provider (OpenCode Go / Anthropic format) ──────────────────
# Uncomment to route through OpenCode Go. On Go, MiniMax M3 / Qwen3.7 are served
# at /v1/messages (Anthropic format); GLM / Kimi / DeepSeek / MiMo are at
# /v1/chat/completions (OpenAI format). Bare model id only — "minimax-m3", not
# "minimax-m3[1m]" (the [1m] suffix is CLI-only and is rejected by the API).
#
# VISION_PROVIDER=anthropic
# VISION_BASE_URL=https://opencode.ai/zen/go
# VISION_API_KEY=your-gateway-key-here
# VISION_MODEL=minimax-m3
#
# # Anthropic provider-specific fallbacks (used only if VISION_* unset):
# ANTHROPIC_BASE_URL=https://opencode.ai/zen/go
# ANTHROPIC_API_KEY=your-anthropic-or-gateway-key-here
# ANTHROPIC_MODEL=minimax-m3
#
# # OpenAI provider-specific fallbacks (used only if VISION_* unset):
# OPENAI_BASE_URL=https://opencode.ai/zen/v1
# OPENAI_API_KEY=your-openai-or-gateway-key-here
# OPENAI_MODEL=minimax-m2.5
